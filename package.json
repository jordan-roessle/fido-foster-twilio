{
  "name": "fido-foster-twilio",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "build:lambda": "tsx scripts/build-lambda.ts",
    "deploy:lambda:auth": "tsx scripts/build-lambda.ts --lambda auth && aws lambda update-function-code --function-name fido-foster-twilio-auth --zip-file fileb://apps/serverless/auth/dist/main.zip --region us-east-1",
    "deploy:lambda:send": "tsx scripts/build-lambda.ts --lambda send && aws lambda update-function-code --function-name fido-foster-twilio-send --zip-file fileb://apps/serverless/send/dist/main.zip --region us-east-1",
    "deploy:lambda:upload": "tsx scripts/build-lambda.ts --lambda upload && aws lambda update-function-code --function-name fido-foster-twilio-upload --zip-file fileb://apps/serverless/upload/dist/main.zip --region us-east-1",
    "deploy:ui": "nx build ui && aws s3 sync apps/ui/dist s3://fido-foster-twilio-frontend-prod --delete --region us-east-1 && aws cloudfront create-invalidation --distribution-id ED9301C643QPL --paths /* --region us-east-1"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nx/esbuild": "22.7.2",
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/jest": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/node": "22.7.2",
    "@nx/react": "22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@nx/web": "22.7.2",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "~0.2.38",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "~30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "commander": "^14.0.3",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.7.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "apps/serverless/*"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "axios": "^1.16.1",
    "googleapis": "^172.0.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twilio": "^6.0.2"
  }
}
